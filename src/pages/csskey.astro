---
import Main from "../layouts/Main.astro";
---

<Main title="CSS Key">
  <main>
    <section class="ar" x-data="{ showModal: false, dialog : null}" x-init="() => dialog=$el" @keydown.escape="showModal = false;" x-cloak>
        <button type="button" class="bg-transparent border border-gray-500 hover:border-indigo-500 text-gray-500 hover:text-indigo-500 font-bold py-2 px-4 rounded-full" @click="showModal = true; document.getElementById('ar-dialog').showModal()">Open modal</button>
        <dialog id="ar-dialog" class="w-full h-full backdrop:bg-current opacity-10" @keydown.escape="showModal = false">
      <form class="ar">
        <input class="ar" type="radio" name="fancy" autofocus value="clubs" id="clubs" />
        <input class="ar" type="radio" name="fancy" value="hearts" id="hearts" />
        <input class="ar" type="radio" name="fancy" value="spades" id="spades" />
        <input class="ar" type="radio" name="fancy" value="diamonds" id="diamonds" />
        <label class="ar" for="clubs">&#9827; Clubs</label><label class="ar" for="hearts"
          >&#9829; Hearts</label  class="ar"
        ><label class="ar" for="spades">&#9824; Spades</label><label class="ar" for="diamonds"
          >&#9830; Diamonds</label
        >

        <div class="ar keys">Use left and right keys to navigate</div>
      </form>
      </dialog>
    </section>
  </main>
</Main>
<style>

    label.ar {
      background: #444;
      color: #fff;
      transition: transform 400ms ease-out;
      display: inline-block;
      min-height: 100%;
      width: 100%;
      height: 100%;
      position: relative;
      z-index: 1;
      text-align: center;
      line-height: 100vh;
    }

    form.ar {
      position: absolute;
      top: 0;
      left: 0;
      bottom: 0;
      right: 0;
      white-space: nowrap;
      overflow: hidden;
    }
    input.ar {
      position: absolute;
    }

    keys.ar {
      position: fixed;
      z-index: 10;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 2rem;
      color: #fff;
      text-align: center;
      transition: all 300ms linear;
      opacity: 0;
    }

    input.ar:focus ~ .keys {
      opacity: 0.8;
    }

    input.ar:nth-of-type(1):checked ~ label:nth-of-type(1),
    input.ar:nth-of-type(2):checked ~ label:nth-of-type(2),
    input.ar:nth-of-type(3):checked ~ label:nth-of-type(3),
    input.ar:nth-of-type(4):checked ~ label:nth-of-type(4) {
      z-index: 0;
    }

    input.ar:nth-of-type(1):checked ~ label {
      transform: translate3d(0, 0, 0);
    }

    input.ar:nth-of-type(2):checked ~ label {
      transform: translate3d(-100%, 0, 0);
    }

    input.ar:nth-of-type(3):checked ~ label {
      transform: translate3d(-200%, 0, 0);
    }

    input.ar:nth-of-type(4):checked ~ label {
      transform: translate3d(-300%, 0, 0);
    }

    label.ar {
      background: #444;
      background-size: cover;
      font-size: 3rem;
    }

    label.ar[for="diamonds"],
    label.ar[for="hearts"] {
      background: #cc0000;
    }

    label.ar:before,
    label.ar:after {
      color: white;
      display: block;
      background: rgba(255, 255, 255, 0.2);
      position: absolute;
      padding: 1rem;
      font-size: 3rem;
      -x-height: 10rem;
      vertical-align: middle;
      line-height: 3rem;
      top: 50%;
      transform: translate3d(0, -50%, 0);
      cursor: pointer;
    }

    label.ar:before {
      content: "\276D";
      right: 100%;
      -x-border-top-left-radius: 50%;
      -x-border-bottom-left-radius: 50%;
    }

    label.ar:after {
      content: "\276C";
      left: 100%;
      -x-border-top-right-radius: 50%;
      -x-border-bottom-right-radius: 50%;
    }

</style>
