---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Main from "../../layouts/Main.astro";
import Thumbnail from "../../components/Thumbnail.astro";
import FormattedDate from "../../components/FormattedDate.astro";

let artists = await getCollection("artists");
artists = artists
  .filter((artist) => !artist.data.hidden)
  .sort((a, b) => {
    return a.data.title.localeCompare(b.data.title);
  });
---

<Main title="The Artists">
  <main>
    <section>
      <ul class="flex flex-wrap gap-3 justify-evenly">
        {
          artists.map((artist) => (
            <li class="w-full md:w-1/3 lg:w-1/4 xl:w-1/5 xxl:w-1/6 p-4">
              <a href={`/artists/${artist.slug}`}>
                <Thumbnail
                  src={artist.data.featuredImage}
                  alt={artist.data.title}
                  title={artist.data.title}
                  href={`/artists-x/${artist.slug}`}
                >
                  <div class="h-full">
                    <h5 class=" text-balance">{artist.data.title}</h5>
                  </div>
                </Thumbnail>
              </a>
            </li>
          ))
        }

        <li class="h-0 w-full md:w-1/3 lg:w-1/4 xl:w-1/5 xxl:w-1/6 p-4">
          &nbsp;
        </li>
        <li class="h-0 w-full md:w-1/3 lg:w-1/4 xl:w-1/5 xxl:w-1/6 p-4">
          &nbsp;
        </li>
        <li class="h-0 w-full md:w-1/3 lg:w-1/4 xl:w-1/5 xxl:w-1/6 p-4">
          &nbsp;
        </li>
        <li class="h-0 w-full md:w-1/3 lg:w-1/4 xl:w-1/5 xxl:w-1/6 p-4">
          &nbsp;
        </li>
        <li class="h-0 w-full md:w-1/3 lg:w-1/4 xl:w-1/5 xxl:w-1/6 p-4">
          &nbsp;
        </li>
        <li class="h-0 w-full md:w-1/3 lg:w-1/4 xl:w-1/5 xxl:w-1/6 p-4">
          &nbsp;
        </li>
      </ul>
    </section>
  </main>
</Main>
