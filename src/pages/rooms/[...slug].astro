---
import { type CollectionEntry, getCollection } from "astro:content";
import { Image } from "astro:assets";
import Main from "../../layouts/Main.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Thumbnail from "../../components/Thumbnail.astro";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
  let rooms = await getCollection("rooms");
  return rooms
    .filter((room) => room.data.hidden !== true)
    .map((room) => ({
      params: { slug: room.slug },
      props: room,
    }));
}
type Props = CollectionEntry<"rooms">;

const room = Astro.props;
const { Content } = await room.render();

const artists = await getCollection("artists");
---

<Main title={`${room.data.title}`}>
  <main>
    <section>

      <div x-data x-init="() => {window.$refs = $refs;}">
        <ul class="flex flex-wrap gap-4 justify-between">
          {
            room.data.images?.map((image, i) => (
              <li class="w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12" @click.prevent= {` () => {$refs.dialog.showModal(); document.getElementById('p${i}').scrollIntoView(); } `}>
                <Thumbnail src={image} alt={room.data.title} title={room.data.title}/>
              </li>
            ))
          }
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
          <li class="h-0 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 xl:w-1/6 xxl:w-1/12">&nbsp;</li>
        </ul>

        <dialog
          x-ref="dialog"
          xx-transition
          id="thumb-dialog"
          class="w-full h-full bg-transparent backdrop:bg-black backdrop:opacity-90 transition-all duration-1000 opacity-0 open:opacity-100"
        >
          <button
            @click="() => {dialog_open = false; $refs.dialog.close();}"
            class="absolute top-0 right-0 focus-visible:outline-none text-white z-10"
            ><Icon
              name="material-symbols-light:close"
              class="size-8 lg:size-16"
            />
          </button>

          <div
            class="h-full w-11/12 flex flex-col justify-center items-center mx-auto"
          >
            <div class="carousel w-full">
              {
                room.data.images?.map((image, i, images) => (
                  <div id={`p${i}`} class="carousel-item relative w-full duration-75">
                    <Image
                      src={image}
                      alt={room.data.title}
                      title={room.data.title}
                      widths={[360, 1600]}
                      sizes={`(max-width: 360px) 360px, 1600px`}
                      class="xw-full object-contain"
                    />
                    <div class="absolute flex justify-between transform -translate-y-1/2 left-0 right-0 top-1/2">
                      <a href={`#p${ i === 0 ? images.length-1 : i-1 } `} class="hidden lg:btn btn-circle !rounded-none !bg-[--main-background] !text-2xl !border-none"
                      @click.prevent="() => {document.getElementById($el.href.split('#').pop()).scrollIntoView({behavior: 'smooth'})}"
                      >
                        ❮❮
                      </a>
                      <a href={`#p${ i === images.length-1 ? 0 : i+1 } `} class="hidden lg:btn btn-circle !rounded-none !bg-[--main-background] !text-2xl !border-none"
                      @click.prevent="() => {document.getElementById($el.href.split('#').pop()).scrollIntoView({behavior: 'smooth'})}"
                      >
                        ❯❯
                      </a>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </dialog>
      </div>


      <h2>
        <FormattedDate date={room.data.startdate} /> - {room.data.enddate && <FormattedDate date={room.data.enddate} /> || `ONGOING`}
      </h2>
      <div class="max-w-4xl">
        <Content />
      </div>
      <div>
        <h4>
          About the artist{room.data.artists.length > 1 && "s"}:
        </h4>
        {
          room.data.artists.map((artist, a, i) => (
            <>
              <a href={`/artists/${artist}`}>
                {artists.find((a) => a.slug == artist)?.data.title}
              </a>
              {i.length - 1 > a && <span>, </span>}
            </>
          ))
        }
      </div>
    </section>
  </main>
</Main>
