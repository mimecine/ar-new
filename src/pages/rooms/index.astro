---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Main from '../../layouts/Main.astro';
import  FormattedDate  from "../../components/FormattedDate.astro";
let rooms = (await getCollection("rooms"));
const continuos = new Date(2100, 1, 1);
rooms = rooms.filter((room) =>!room.data.hidden).sort((a, b) => {
    let date = (b.data.enddate||continuos) - (a.data.enddate||continuos)
    return  date;
    })
    .sort((a, b) => {
      return a.data.priority > b.data.priority ? -1 : 1;
    });
---
<Main title="Artist Rooms - The Rooms">
<main>
  <section>
    <ul class="flex flex-wrap">
      {
        rooms.filter(room => !room.hidden).map((room) => (
          <li class="room w-full md:w-1/2 lg:w-1/3 xl:w-1/4 xxl:w-1/5 p-4">
            <a href={`/rooms/${room.slug}/`}>
              {room.data.images?.length && <Image
                width={500}
                src={room.data.images[0]}
                alt={room.data.title}
                class="max-w-full h-64 w-auto object-cover"
              />}
              <h4 class="title text-pretty text-2xl w-3/4">{room.data.title}</h4>
              <!--  <p class="town">{room.data.town}</p> -->
              <p class="date text-lg">
                <FormattedDate date={room.data.startdate}/> {room.data.enddate && (<> - <FormattedDate date={room.data.enddate}/></>)}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</main>
</Main>
