{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "start": "concurrently npm:dev npm:cms",
    "dev": "bun astro dev --host",
    "build": "bun astro build",
    "deploy": "vercel --dist",
    "preview": "astro preview --host",
    "cms": "npm exec @staticcms/proxy-server",
    "make data": "rm -rf src/content/{rooms,artists,venues,films} && bun scripts/make_md.mjs",
    "scrape": "bun scripts/crawler-artists.js && bun scripts/crawler-rooms.js && bun scripts/crawler-films.js",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.4.0",
    "@astrojs/check": "^0.5.10",
    "@astrojs/mdx": "^2.3.1",
    "@astrojs/netlify": "^5.5.0",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.1.6",
    "@astrojs/tailwind": "^5.1.0",
    "@extractus/oembed-extractor": "^4.0.5",
    "@fontsource-variable/fredoka": "^5.0.13",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "@types/alpinejs": "^3.13.10",
    "alpinejs": "^3.14.1",
    "astro": "^4.13.1",
    "astro-embed": "^0.6.2",
    "astro-icon": "^1.1.0",
    "astro-pagefind": "^1.6.0",
    "caniuse-lite": "^1.0.30001649",
    "core-js": "^3.38.0",
    "crawler": "^1.5.0",
    "dotenv": "^16.4.5",
    "import": "^0.0.6",
    "leaflet": "^1.9.4",
    "marked": "^12.0.2",
    "smoothscroll-polyfill": "^0.4.4",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.1.86",
    "@iconify-json/material-symbols-light": "^1.1.26",
    "@iconify-json/mdi": "^1.1.68",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "concurrently": "^8.2.2",
    "install": "^0.13.0",
    "nodejs-web-scraper": "^6.1.3",
    "yaml": "^2.5.0"
  },
  "trustedDependencies": [
    "core-js"
  ]
}
