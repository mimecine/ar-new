{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "start": "concurrently npm:dev npm:cms",
    "dev": "bun astro dev --host",
    "build": "bun astro build",
    "deploy": "vercel --dist",
    "preview": "astro preview --host",
    "cms": "npm exec @staticcms/proxy-server",
    "make data": "rm -rf src/content/{rooms,artists,venues,films} && bun scripts/make_md.mjs",
    "scrape": "bun scripts/crawler-artists.js && bun scripts/crawler-rooms.js && bun scripts/crawler-films.js",
    "astro": "astro"
  },
  "dependencies": {
    "@alpinejs/persist": "^3.14.1",
    "@astrojs/alpinejs": "^0.4.0",
    "@astrojs/check": "0.9.4",
    "@astrojs/mdx": "3.1.7",
    "@astrojs/netlify": "5.5.3",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "3.2.0",
    "@astrojs/tailwind": "5.1.1",
    "@extractus/oembed-extractor": "^4.0.5",
    "@fontsource-variable/fredoka": "^5.1.0",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "@types/alpinejs": "^3.13.10",
    "alpinejs": "^3.14.1",
    "astro": "4.15.12",
    "astro-embed": "^0.6.2",
    "astro-icon": "^1.1.1",
    "astro-pagefind": "^1.6.0",
    "caniuse-lite": "^1.0.30001667",
    "core-js": "^3.38.1",
    "crawler": "^1.5.0",
    "dotenv": "^16.4.5",
    "import": "^0.0.6",
    "leaflet": "^1.9.4",
    "marked": "^12.0.2",
    "sharp": "^0.33.5",
    "smoothscroll-polyfill": "^0.4.4",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.3",
    "@iconify-json/material-symbols-light": "^1.2.3",
    "@iconify-json/mdi": "^1.2.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "concurrently": "^8.2.2",
    "install": "^0.13.0",
    "nodejs-web-scraper": "^6.1.3",
    "yaml": "^2.5.1"
  },
  "trustedDependencies": [
    "core-js"
  ]
}
