{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "start": "concurrently npm:dev npm:cms",
    "dev": "bun astro dev",
    "build": "bun astro build",
    "deploy": "vercel --dist",
    "preview": "astro preview",
    "cms": "npm exec @staticcms/proxy-server",
    "make data": "rm -rf src/content/{rooms,artists,venues} && bun scripts/make_md.mjs",
    "scrape": "bun scripts/crawler-artists.js && bun scripts/crawler-rooms.js",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.4.0",
    "@astrojs/check": "^0.5.4",
    "@astrojs/mdx": "^2.1.1",
    "@astrojs/netlify": "^5.2.0",
    "@astrojs/rss": "^4.0.4",
    "@astrojs/sitemap": "^3.0.5",
    "@astrojs/tailwind": "^5.1.0",
    "@extractus/oembed-extractor": "^4.0.3",
    "@fontsource-variable/fredoka": "^5.0.13",
    "@googlemaps/google-maps-services-js": "^3.3.42",
    "@types/alpinejs": "^3.13.6",
    "alpinejs": "^3.13.5",
    "astro": "^4.4.0",
    "astro-embed": "^0.6.1",
    "astro-icon": "^1.1.0",
    "astro-pagefind": "^1.5.0",
    "core-js": "^3.37.1",
    "crawler": "^1.5.0",
    "dotenv": "^16.4.5",
    "import": "^0.0.6",
    "leaflet": "^1.9.4",
    "marked": "^12.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.1.73",
    "@iconify-json/material-symbols-light": "^1.1.13",
    "@iconify-json/mdi": "^1.1.64",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.12",
    "concurrently": "^8.2.2",
    "install": "^0.13.0",
    "nodejs-web-scraper": "^6.1.3",
    "yaml": "^2.3.4"
  }
}
